# SQLite DB（省略時は ./data.db）
# DATABASE_URL=sqlite:./data.db

# 管理画面ログイン用パスワード
ADMIN_PASSWORD=admin

# JWT 署名用（本番では長いランダム文字列に変更）
JWT_SECRET=change-me-in-production

# アップロード保存先（省略時は ./uploads）
# UPLOAD_DIR=uploads

# API のベースURL（お知らせ画像の絶対URL用。本番では https://your-domain.com など）
# API_BASE_URL=http://localhost:3002

# ポート（省略時は 3002）
# PORT=3002

# お問い合わせフォーム送信用（Gmail の場合は 2 段階認証＋アプリ パスワード）。スペースを含む場合は引用符で囲む
# CONTACT_EMAIL_USER=your@gmail.com
# CONTACT_EMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

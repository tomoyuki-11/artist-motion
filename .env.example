# お問い合わせ・お知らせ・管理画面は Rust (api) で動作。api/.env に CONTACT_EMAIL_* を設定。
# CONTACT_EMAIL_USER=your@gmail.com
# CONTACT_EMAIL_APP_PASSWORD="xxxx xxxx xxxx xxxx"

# サイト用 API（Rust）の URL（開発時は npm run dev:api でポート 3002 起動）
# VITE_ADMIN_API_URL=http://localhost:3002

# 本番のサイトURL（SEO: canonical, OGP, sitemap で使用）。未設定時はブラウザの origin を使用
# VITE_SITE_URL=https://artist-motion.com

# 管理画面ログインで OAuth を使う場合（任意）
# VITE_OAUTH_PORTAL_URL=https://your-oauth-portal.example.com
# VITE_APP_ID=your-app-id

# 地図表示で Forge を使う場合（任意）
# VITE_FRONTEND_FORGE_API_KEY=your-api-key
# VITE_FRONTEND_FORGE_API_URL=https://your-forge-api.example.com
